{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "rootDir": "src/modules",
    "outDir": "public/js",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src/modules/**/*.ts"]
}
