{
  "name": "minagrow-minaplay",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build:client && tsx server.ts",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "tsc -p tsconfig.client.json",
    "build": "npm run build:server && npm run build:client",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "lint": "eslint \"server.ts\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run tests/segmentation.test.ts tests/webhook-verify.test.ts",
    "test:e2e": "playwright test tests/playwright"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "lowdb": "^7.0.1",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.22.0",
    "playwright": "^1.58.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
